[Unit]
Description=Tour Hunter Telegram Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tour-hunter-bot
EnvironmentFile=/opt/tour-hunter-bot/.env
ExecStart=/opt/tour-hunter-bot/.venv/bin/python -m app.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
